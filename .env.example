# Okta Configuration
# Your Okta developer org domain — no "https://", no trailing slash
# Example: dev-12345678.okta.com
OKTA_DOMAIN=your-dev-org.okta.com

# Okta API Token
# Generate in Okta Admin Console: Security > API > Tokens > Create Token
# Needs SUPER_ADMIN to create users, groups, and assign admin roles
OKTA_API_TOKEN=your-okta-api-token-here
